# Session signing secret (required — use a long random string)
AUTH_SECRET=change_me_to_a_long_random_secret_string

# Auto-assign admin role when this email signs up (server-only)
ADMIN_EMAIL=your-email@example.com

# Supabase (required for authentication)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Gemini (script generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Stripe (subscription billing) — use test keys in dev, live keys in production
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PRO=price_your_pro_price_id
STRIPE_PRICE_TEAM=price_your_team_price_id

# Upstash Redis (recommended for production rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Optional: API key encryption for AI settings (32-byte hex)
# API_KEY_ENCRYPTION_SECRET=your_64_char_hex_secret
